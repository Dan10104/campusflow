# Docker Compose usa el prefijo CAMPUSFLOW_ para no leer accidentalmente
# valores privados del .env local de Laravel durante la interpolacion.
# Dentro del contenedor se mapean a APP_NAME, APP_KEY, DB_* y demas variables normales.

CAMPUSFLOW_APP_NAME=CampusFlow
CAMPUSFLOW_APP_ENV=local
CAMPUSFLOW_APP_DEBUG=true
CAMPUSFLOW_APP_URL=http://localhost:8080
CAMPUSFLOW_APP_KEY=
CAMPUSFLOW_APP_LOCALE=es
CAMPUSFLOW_APP_FALLBACK_LOCALE=es
CAMPUSFLOW_APP_FAKER_LOCALE=es_BO

CAMPUSFLOW_LOG_CHANNEL=stderr
CAMPUSFLOW_LOG_LEVEL=debug

CAMPUSFLOW_DB_DATABASE=ProyectoFinal
CAMPUSFLOW_DB_USERNAME=campusflow
CAMPUSFLOW_DB_PASSWORD=CAMBIAR_ESTA_CONTRASENA
CAMPUSFLOW_MYSQL_ROOT_PASSWORD=CAMBIAR_ROOT_PASSWORD

CAMPUSFLOW_SESSION_DRIVER=database
CAMPUSFLOW_SESSION_LIFETIME=120
CAMPUSFLOW_CACHE_DRIVER=database
CAMPUSFLOW_CACHE_STORE=database
CAMPUSFLOW_QUEUE_CONNECTION=database
CAMPUSFLOW_BROADCAST_CONNECTION=log
CAMPUSFLOW_FILESYSTEM_DISK=local

CAMPUSFLOW_MAIL_MAILER=log

CAMPUSFLOW_RUN_MIGRATIONS=true
CAMPUSFLOW_DB_WAIT_TIMEOUT=60
CAMPUSFLOW_PORT=8080
CAMPUSFLOW_VITE_APP_NAME=CampusFlow
